### 12.7 State Machine Guard (validate status transitions)
```go
package service

var validTransitions = map[string][]string{
    "Scheduled": {"Present", "Absent", "Late", "HalfDay", "Holiday", "Leave"},
    "Absent":    {"Notified", "Locked"},
    "Notified":  {"Query", "Absent"},
    "Query":     {"Present", "Absent"},
    "Locked":    {"Override", "Archived"},
    "Override":  {"Present", "Absent"},
}

func ValidateStatusTransition(current, next string) error {
    allowed, exists := validTransitions[current]
    if !exists {
        return fmt.Errorf("invalid current status: %s", current)
    }
    
    for _, status := range allowed {
        if status == next {
            return nil
        }
    }
    
    return fmt.Errorf("invalid transition from %s to %s", current, next)
}
```

