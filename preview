### 12.4 HMAC Signature Verifier (for biometric devices)
```go
package middleware

import (
    "crypto/hmac"
    "crypto/sha256"
    "encoding/hex"
    "io"
    "net/http"
)

func DeviceAuthMiddleware(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        deviceID := r.Header.Get("X-Device-ID")
        signature := r.Header.Get("X-Signature")
        
        if deviceID == "" || signature == "" {
            http.Error(w, "Missing device credentials", http.StatusUnauthorized)
            return
        }
        
        // Fetch HMAC secret from DB or cache
        secret, err := repo.GetDeviceHMACSecret(r.Context(), deviceID)
        if err != nil {
            http.Error(w, "Device not registered", http.StatusUnauthorized)
            return
        }
        
        // Read body for verification
        body, err := io.ReadAll(r.Body)
        if err != nil {
            http.Error(w, "Cannot read body", http.StatusBadRequest)
            return
        }
        
        // Restore body for downstream handlers
        r.Body = io.NopCloser(bytes.NewBuffer(body))
        
        // Verify HMAC-SHA256
        h := hmac.New(sha256.New, []byte(secret))
        h.Write(body)
        expectedSig := hex.EncodeToString(h.Sum(nil))
        
        if !hmac.Equal([]byte(signature), []byte(expectedSig)) {
            http.Error(w, "Invalid signature", http.StatusUnauthorized)
            return
        }
        
        next.ServeHTTP(w, r)
    })
}
```

